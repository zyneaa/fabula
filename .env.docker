# Docker environment variables
# Copy this file to .env and update the values

# OpenRouter API Key (required for LLM features)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Database credentials (already configured in docker-compose.yml)
# DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/fabula

# JWT settings
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# LLM settings
DEFAULT_LLM_MODEL=google/gemma-4-26b-a4b-it

# Upload settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# CORS origins (comma-separated list)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost"]
